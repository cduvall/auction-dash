  "scripts": {
    "dev": "concurrently \"node server.js\" \"vite\"",
    "dev:cf": "npm run build && npx wrangler pages dev dist --d1 DB=auction-dash-db",
    "build": "vite build",
    "deploy": "npm run build && npx wrangler pages deploy dist",
